# 6. Model wrapper
# Add groupmate models here later

fit_predict_models <- function(x_train, y_train, x_test) {
  
  preds <- list()
  
  # -----------------------------
  # Model 1: LASSO
  # -----------------------------
  set.seed(123)
  
  lasso_model <- cv.glmnet(
    x = x_train,
    y = y_train,
    alpha = 1
  )
  
  preds[["LASSO"]] <- as.numeric(
    predict(lasso_model, s = "lambda.min", newx = x_test)
  )
  
  # -----------------------------
  # Add groupmate models here
  # -----------------------------

  
  return(preds)
}


# 7. Run 5-fold CV

for (fold in 1:k) {
  
  cat("\nRunning fold:", fold, "\n")
  
  test_idx <- which(fold_id == fold)
  train_idx <- which(fold_id != fold)
  
  x_train <- X[train_idx, ]
  y_train <- y_log[train_idx]
  
  x_test <- X[test_idx, ]
  y_test_log <- y_log[test_idx]
  y_test_vol <- y_vol[test_idx]
  
  pred_list <- fit_predict_models(x_train, y_train, x_test)
  
  for (model_name in names(pred_list)) {
    
    pred_log <- pred_list[[model_name]]
    pred_vol <- exp(pred_log)
    
    rmse_log <- rmse_fun(y_test_log, pred_log)
    qlike_val <- qlike_fun(y_test_vol, pred_vol)
    
    cv_results <- rbind(
      cv_results,
      data.table(
        fold = fold,
        model = model_name,
        rmse_log = rmse_log,
        qlike = qlike_val
      )
    )
    
    prediction_store[[paste(model_name, fold, sep = "_")]] <- data.table(
      fold = fold,
      model = model_name,
      stock_id = model_data$stock_id[test_idx],
      time_id = model_data$time_id[test_idx],
      actual_log_vol = y_test_log,
      predicted_log_vol = pred_log,
      actual_vol = y_test_vol,
      predicted_vol = pred_vol
    )
  }
}


