        "    (\"Run status\", run_status.get(\"status\", \"\")),\n",
        "    (\"Stocks modelled\", run_status.get(\"n_stocks\", len(data_config.get(\"stocks\", [])))),\n",
        "    (\"Feature rows\", f\"{int(run_status.get('n_feature_rows', 0)):,}\" if run_status else \"\"),\n",
        "    (\"Predictions\", f\"{int(run_status.get('n_predictions', 0)):,}\" if run_status else \"\"),\n",
        "    (\"Cross-validation folds\", run_status.get(\"n_folds\", \"\")),\n",
        "    (\"Forecast horizon\", f\"{feature_config.get('forecast_horizon', '')} seconds\"),\n",
        "    (\"Feature mode\", feature_config.get(\"feature_mode\", \"\")),\n",
        "    (\"PCA components in run config\", feature_config.get(\"n_pca_components\", \"\")),\n",
        "    (\"Feature source\", run_status.get(\"feature_source\", \"\")),\n",
        "    (\"Feature cache created\", feature_cache_manifest.get(\"created_at_utc\", \"\")),\n",
        "]\n",
        "\n",
