      "source": [
        "#| label: setup\n",
        "\n",
        "from pathlib import Path\n",
        "import json\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from IPython.display import HTML, display\n",
        "\n",
        "from back_end.config import ARTIFACTS_DIR, FeatureConfig, INDIVIDUAL_BOOK_DIR, ROOT_DIR\n",
        "from back_end.universe import build_model_comparison\n",
        "from back_end.universe import build_pca_variance_explained\n",
        "\n",
        "PROJECT_ROOT = ROOT_DIR\n",
        "RAW_DATA_DIR = INDIVIDUAL_BOOK_DIR\n",
        "\n",
        "\n",
        "def artifact_path(*parts: str) -> Path:\n",
        "    return ARTIFACTS_DIR.joinpath(*parts)\n",
        "\n",
        "\n",
        "RUNS_DIR = artifact_path(\"runs\")\n",
        "FEATURE_CACHE_PATH = artifact_path(\"feature_cache\", \"features_all_stocks.parquet\")\n",
        "FEATURE_CACHE_MANIFEST_PATH = artifact_path(\"feature_cache\", \"manifest.json\")\n",
        "\n",
        "\n",
        "def latest_run_dir() -> Path | None:\n",
        "    if not RUNS_DIR.exists():\n",
        "        return None\n",
        "    run_dirs = sorted([path for path in RUNS_DIR.iterdir() if path.is_dir()], reverse=True)\n",
        "    return run_dirs[0] if run_dirs else None\n",
        "\n",
        "\n",
        "RUN_DIR = latest_run_dir()\n",
        "\n",
        "\n",
        "def load_artifact(name: str) -> pd.DataFrame:\n",
        "    if RUN_DIR is None:\n",
        "        return pd.DataFrame()\n",
        "    path = RUN_DIR / name\n",
        "    if not path.exists():\n",
        "        return pd.DataFrame()\n",
        "    return pd.read_parquet(path)\n",
        "\n",
        "\n",
        "def load_feature_targets() -> pd.DataFrame:\n",
        "    if not FEATURE_CACHE_PATH.exists():\n",
        "        return pd.DataFrame()\n",
        "    return pd.read_parquet(\n",
        "        FEATURE_CACHE_PATH,\n",
        "        columns=[\"stock_id\", \"time_id\", \"target_var\", \"target_vol\"],\n",
        "    )\n",
        "\n",
        "\n",
        "def load_feature_cache() -> pd.DataFrame:\n",
        "    if not FEATURE_CACHE_PATH.exists():\n",
        "        return pd.DataFrame()\n",
        "    return pd.read_parquet(FEATURE_CACHE_PATH)\n",
        "\n",
        "\n",
        "def load_json(path: Path) -> dict:\n",
        "    if not path.exists():\n",
        "        return {}\n",
        "    return json.loads(path.read_text())\n",
        "\n",
        "\n",
        "metrics = load_artifact(\"metrics.parquet\")\n",
        "predictions = load_artifact(\"predictions.parquet\")\n",
        "feature_importance = load_artifact(\"feature_importance.parquet\")\n",
        "universe_summary = load_artifact(\"universe_summary.parquet\")\n",
        "stock_similarity = load_artifact(\"stock_similarity.parquet\")\n",
        "feature_targets = load_feature_targets()\n",
        "feature_cache_manifest = load_json(FEATURE_CACHE_MANIFEST_PATH)\n",
        "\n",
        "\n",
        "def model_summary_frame(metrics_df: pd.DataFrame, predictions_df: pd.DataFrame) -> pd.DataFrame:\n",
        "    if metrics_df.empty or predictions_df.empty:\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    metric_cols = [\"mse\", \"rmse\", \"mae\", \"mape\", \"rmspe\", \"qlike\", \"pearson_r\"]\n",
        "    available_metrics = [col for col in metric_cols if col in metrics_df.columns]\n",
        "    overall = metrics_df.copy()\n",
        "    if \"fold\" in overall.columns:\n",
        "        overall = overall[overall[\"fold\"] == 0].copy()\n",
        "\n",
        "    summary = overall[[\"model\", *available_metrics]].copy()\n",
        "    latency = (\n",
        "        predictions_df.groupby(\"model\", as_index=False)\n",
        "        .agg(\n",
        "            mean_inference_us=(\"inference_ms\", lambda values: values.mean() * 1000),\n",
        "            n_predictions=(\"model\", \"size\"),\n",
        "        )\n",
        "    )\n",
        "    return summary.merge(latency, on=\"model\", how=\"left\")\n",
        "\n",
        "\n",
        "def cached_model_comparison_table(metrics_df: pd.DataFrame, predictions_df: pd.DataFrame) -> pd.DataFrame:\n",
        "    columns = [\n",
        "        \"Model\",\n",
        "        \"Mean inference (μs)\",\n",
        "        \"RMSE model wins\",\n",
        "        \"↓ QLIKE model wins\",\n",
        "        \"RMSE\",\n",
        "        \"QLIKE\",\n",
        "        \"MAE\",\n",
        "        \"MSE\",\n",
        "    ]\n",
        "    if metrics_df.empty and predictions_df.empty:\n",
        "        return pd.DataFrame(columns=columns)\n",
        "\n",
        "    comparison = build_model_comparison(predictions_df, metrics_df)\n",
        "    if comparison.empty:\n",
        "        return pd.DataFrame(columns=columns)\n",
        "\n",
        "    table = comparison[\n",
        "        [\n",
        "            \"model\",\n",
        "            \"mean_inference_ms\",\n",
        "            \"best_stocks_rmse\",\n",
        "            \"best_stocks_qlike\",\n",
        "            \"rmse\",\n",
        "            \"qlike\",\n",
        "            \"mae\",\n",
        "            \"mse\",\n",
        "        ]\n",
        "    ].copy()\n",
        "    table[\"mean_inference_ms\"] = table[\"mean_inference_ms\"] * 1000\n",
        "    table = table.rename(\n",
        "        columns={\n",
        "            \"model\": \"Model\",\n",
        "            \"mean_inference_ms\": \"Mean inference (μs)\",\n",
        "            \"best_stocks_rmse\": \"RMSE model wins\",\n",
        "            \"best_stocks_qlike\": \"↓ QLIKE model wins\",\n",
        "            \"rmse\": \"RMSE\",\n",
        "            \"qlike\": \"QLIKE\",\n",
        "            \"mae\": \"MAE\",\n",
        "            \"mse\": \"MSE\",\n",
        "        }\n",
        "    )\n",
        "    return table.sort_values(\n",
        "        [\"↓ QLIKE model wins\", \"RMSE\", \"Model\"],\n",
        "        ascending=[False, True, True],\n",
        "        na_position=\"last\",\n",
        "    ).reset_index(drop=True)\n",
        "\n",
        "\n",
        "def format_report_table(frame: pd.DataFrame) -> pd.DataFrame:\n",
        "    formatted = frame.copy()\n",
        "    integer_cols = [\"RMSE model wins\", \"↓ QLIKE model wins\"]\n",
        "    numeric_cols = [col for col in formatted.columns if col not in [\"Model\", *integer_cols]]\n",
        "    for col in integer_cols:\n",
        "        if col in formatted.columns:\n",
        "            formatted[col] = formatted[col].map(lambda value: \"\" if pd.isna(value) else f\"{int(value)}\")\n",
        "    for col in numeric_cols:\n",
        "        formatted[col] = formatted[col].map(lambda value: \"\" if pd.isna(value) else f\"{float(value):.3f}\")\n",
        "    return formatted\n",
        "\n",
        "\n",
        "def pareto_optimal_mask(frame: pd.DataFrame, x_col: str, y_col: str) -> pd.Series:\n",
        "    mask = []\n",
        "    for _, row in frame.iterrows():\n",
        "        dominated = (\n",
        "            (frame[x_col] <= row[x_col])\n",
        "            & (frame[y_col] <= row[y_col])\n",
        "            & ((frame[x_col] < row[x_col]) | (frame[y_col] < row[y_col]))\n",
        "        ).any()\n",
        "        mask.append(not dominated)\n",
        "    return pd.Series(mask, index=frame.index)\n",
        "\n",
        "\n",
        "def stock_label(stock_id: str) -> str:\n",
        "    text = str(stock_id)\n",
        "    if text.startswith(\"stock_\"):\n",
        "        text = text.removeprefix(\"stock_\")\n",
        "    try:\n",
        "        return f\"Stock {int(text)}\"\n",
        "    except ValueError:\n",
        "        return str(stock_id)"
      ],
      "id": "setup",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Executive summary\n",
        "\n",
        "Problem Description: Volatility forecasting is central to a wide range of financial applications, including option pricing, portfolio optimisation, and risk management. Competitive latency arbitrage races on exchanges have a typical duration of just 5-10 microseconds (Aquilina et al., 2021). Our project aims to help traders answer the question: \"What is the best volatility prediction model for my goal, given latency constraints and given my desired model accuracy?\" This is especially relevant to traders who compete in ultra high frequency domains.\n",
        "\n",
        "Findings: Our results show a clear Pareto frontier, where a trader must choose between a faster model and a model which is more accurate. We found the XGBoost model to have the best tradeoff between inference latency and predictive accuracy, though traders competing in ultra high frequency races may choose differently.\n",
        "\n",
        "Practical Relevance: Supporting traders in choosing volatility forecasting models under both accuracy and latency constraints. This tool helps users compare models under multiple performance metrics and computational costs, bridging statistical model performance and real-world trading requirements.\n",
        "\n",
        "# Background\n",
        "\n",
        "Our research question is: *what is the most accurate volatility prediction model for a given universe of stocks, given latency constraints?*\n",
        "\n",
        "This project helps quantitative researchers and traders choose forecasting models that balance predictive accuracy with computational efficiency in latency-sensitive financial markets. The aim is to evaluate volatility models using many performance metrics to create a tool that helps users identify their desirable model based on statistical performance and real-world trading constraints.\n",
        "\n",
        "Traders use volatility forecasting models for many purposes, including but not limited to modelling inventory risk, portfolio optimisation and value at risk (VaR) analysis (Poon and Granger, 2003). Depending on the application, traders, market makers and portfolio managers require tools which have different accuracy vs latency tradeoffs. For instance, a portfolio manager calculating their one day VaR requires the most accurate volatility model and is likely less worried about inference latency, while a researcher creating an options pricing algorithm for a highly liquid stock may prioritise speed at the cost of some accuracy.\n",
        "\n",
        "Tools like TradingView (TradingView, n.d.) let traders view the price of a given asset over time, and introduce scripting tools which help traders visualise different functions of price, e.g., rolling volatility over time. However, they do not introduce any way for traders to predict future volatility. In order to do this, traders currently must spend significant time to code a volatility prediction model, ensure the correctness of that code, create necessary visualisations, and evaluate against different metrics. Our tool innovates on the current tooling landscape by providing a no code interface, which lets traders and market participants view model latency vs model accuracy tradeoffs in a simple, intuitive manner.\n",
        "\n",
        "We were given two datasets to work with: a dataset of 112 anonymous, unnamed stocks, and a dataset of 10 named stocks. Each dataset contained the top two levels of orderbook data, where price series were split up into differing time_id’s. As the length of the price series within each time_id was not constant between the two datasets, we ultimately chose to model the dataset of 112 anonymous stocks, due to its higher abundance of data, and to ensure that modelling was consistent between different stocks. Notably, each time_id contains 600 seconds of data and the temporal ordering of each time_id has not been preserved.\n",
        "\n",
        "# Methods\n",
        "\n",
        "## Part A: Process\n",
        "\n",
        "### Data Preprocessing\n",
        "\n",
        "Each time_id in the dataset contains 600 seconds of order book data. When seconds were missing within a time_id, we forward filled past values to produce a continuous series without introducing future leakage. Time_ids with fewer than 20 price updates across the first 570 seconds, or fewer than 5 price updates in the final 30 seconds, were dropped to ensure models had an adequate amount of information to generate reliable predictions. The modelling target for all models was the mean realised volatility over the final 30 seconds of each time_id window.\n",
        "\n",
        "### Feature Engineering\n",
        "\n",
        "We computed a range of features from the observed portion of each time_id, excluding the final 30 second forecast horizon. Realised volatility features include rolling mean squared returns and volatility proxies across multiple lookback windows, along with ratios between short and long realised variance windows, following the heterogeneous autoregressive framework of Corsi (2009). Order book microstructure features capture relative bid-ask spread, order book imbalance, top-two-level depth, depth ratios, and book pressure. Volatility trend features include exponentially weighted moving averages of squared returns across four decay parameters. Return behaviour features include lag-1 and lag-5 return autocorrelation, return quantiles, zero return proportions, directional realised variance, and jump counts based on large absolute returns. Because many features are computed from overlapping return windows or related order book quantities, substantial collinearity is expected across the feature set.\n",
        "\n",
        "To address this, our tool offers two feature modes. In Auto mode, the top N principal components of the full feature set (15 by default) are used as model inputs, extracting the maximum amount of orthogonal information while minimising multicollinearity. In Manual mode, the user selects a specific subset of features directly. The appropriate number of components to retain can be guided by the cumulative variance explained plot shown in @fig-pca-cumulative-variance, where the first 15 principal components capture approximately 82% of total feature variance, justifying the default setting."
      ],
      "id": "d9df8f63"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-pca-cumulative-variance\n",
        "#| fig-cap: Cumulative PCA variance.\n",
        "\n",
        "pca_variance = build_pca_variance_explained(load_feature_cache(), FeatureConfig(), 20)\n",
        "\n",
        "if pca_variance.empty:\n",
        "    print(\"No cached feature data was available for the PCA cumulative variance figure.\")\n",
        "else:\n",
        "    plot_df = pca_variance.copy()\n",
        "    plot_df[\"cumulative_variance_ratio\"] = plot_df[\"explained_variance_ratio\"].cumsum()\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(12, 4.8))\n",
        "    ax.plot(\n",
        "        plot_df[\"component\"],\n",
        "        plot_df[\"cumulative_variance_ratio\"],\n",
        "        color=\"#f59f00\",\n",
        "        linewidth=2.5,\n",
        "        marker=\"o\",\n",
        "        markersize=5,\n",
        "    )\n",
        "    ax.set_title(\"Cumulative Variance Explained\", fontweight=\"bold\", loc=\"left\")\n",
        "    ax.set_xlabel(\"Principal component\")\n",
        "    ax.set_ylabel(\"Cumulative variance\")\n",
        "    ax.set_ylim(0, 1)\n",
        "    ax.yaxis.set_major_formatter(lambda value, _: f\"{value:.0%}\")\n",
        "    ax.grid(axis=\"y\", alpha=0.25)\n",
        "    ax.spines[\"top\"].set_visible(False)\n",
        "    ax.spines[\"right\"].set_visible(False)\n",
        "    plt.xticks(rotation=45, ha=\"right\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()"
      ],
      "id": "fig-pca-cumulative-variance",
