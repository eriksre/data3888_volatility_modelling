      "source": [
        "#| label: fig-pareto-frontier\n",
        "#| fig-cap: Accuracy-latency Pareto frontier.\n",
        "\n",
        "import plotly.graph_objects as go\n",
        "\n",
        "model_summary = model_summary_frame(metrics, predictions)\n",
        "pareto_frame = model_summary.dropna(subset=[\"model\", \"mean_inference_us\", \"qlike\"]).copy()\n",
        "pareto_frame = pareto_frame[pareto_frame[\"mean_inference_us\"] > 0].copy()\n",
        "\n",
        "if pareto_frame.empty:\n",
        "    print(\"No cached model metrics were available for the Pareto frontier.\")\n",
        "else:\n",
        "    optimal = pareto_optimal_mask(pareto_frame, \"mean_inference_us\", \"qlike\")\n",
        "\n",
        "    q1, q3 = pareto_frame[\"qlike\"].quantile([0.25, 0.75])\n",
        "    iqr = q3 - q1\n",
        "    qlike_cap = max(q3 + 1.5 * iqr, pareto_frame[\"qlike\"].median())\n",
        "    qlike_cap = min(qlike_cap, pareto_frame[\"qlike\"].max())\n",
        "    pareto_frame[\"qlike_plot\"] = pareto_frame[\"qlike\"].clip(upper=qlike_cap)\n",
        "    pareto_frame[\"qlike_clipped\"] = pareto_frame[\"qlike\"] > qlike_cap\n",
        "    pareto_frame[\"plot_label\"] = pareto_frame.apply(\n",
        "        lambda row: f\"{row['model']} ({row['qlike']:.2f})\"\n",
        "        if row[\"qlike_clipped\"]\n",
        "        else row[\"model\"],\n",
        "        axis=1,\n",
        "    )\n",
        "\n",
        "    pareto_models = pareto_frame[optimal].sort_values(\"mean_inference_us\")\n",
        "    dominated_models = pareto_frame[~optimal].sort_values(\"mean_inference_us\")\n",
        "\n",
        "    fig = go.Figure()\n",
        "\n",
        "    if not dominated_models.empty:\n",
        "        fig.add_trace(go.Scatter(\n",
        "            x=dominated_models[\"mean_inference_us\"],\n",
        "            y=dominated_models[\"qlike_plot\"],\n",
        "            mode=\"markers\",\n",
        "            name=\"Dominated models\",\n",
        "            marker=dict(color=\"gray\", size=10, opacity=0.7),\n",
        "            text=dominated_models[\"model\"],\n",
        "            customdata=dominated_models[[\"qlike\", \"rmse\", \"mae\", \"mse\"]].round(3).values,\n",
        "            hovertemplate=(\n",
        "                \"<b>%{text}</b><br>\"\n",
        "                \"Latency: %{x:.3f} μs<br>\"\n",
        "                \"QLIKE: %{customdata[0]:.4f}<br>\"\n",
        "                \"RMSE: %{customdata[1]}<br>\"\n",
        "                \"MAE: %{customdata[2]}<br>\"\n",
        "                \"MSE: %{customdata[3]}<br>\"\n",
        "                \"<extra></extra>\"\n",
        "            ),\n",
        "        ))\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=pareto_models[\"mean_inference_us\"],\n",
        "        y=pareto_models[\"qlike_plot\"],\n",
        "        mode=\"lines\",\n",
        "        name=\"Pareto frontier\",\n",
        "        line=dict(color=\"red\", width=2),\n",
        "        hoverinfo=\"skip\",\n",
        "    ))\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=pareto_models[\"mean_inference_us\"],\n",
        "        y=pareto_models[\"qlike_plot\"],\n",
        "        mode=\"markers\",\n",
        "        name=\"Pareto optimal\",\n",
        "        marker=dict(color=\"red\", size=12),\n",
        "        text=pareto_models[\"model\"],\n",
        "        customdata=pareto_models[[\"qlike\", \"rmse\", \"mae\", \"mse\"]].round(3).values,\n",
        "        hovertemplate=(\n",
        "            \"<b>%{text}</b><br>\"\n",
        "            \"Latency: %{x:.3f} μs<br>\"\n",
        "            \"QLIKE: %{customdata[0]:.4f}<br>\"\n",
        "            \"RMSE: %{customdata[1]}<br>\"\n",
        "            \"MAE: %{customdata[2]}<br>\"\n",
        "            \"MSE: %{customdata[3]}<br>\"\n",
        "            \"<extra></extra>\"\n",
        "        ),\n",
        "    ))\n",
        "\n",
        "    label_offsets = {\n",
        "        \"LASSO\": (-5, 9),\n",
        "        \"Ridge Regression\": (5, 9),\n",
        "        \"Decision Tree\": (5, -3),\n",
        "        \"Linear Regression\": (7, 6),\n",
        "        \"Random Forest\": (7, -11),\n",
        "        \"GARCH(1,1)\": (6, -10),\n",
        "        \"GJR-GARCH(1,1)\": (6, -10),\n",
        "    }\n",
        "    label_alignments = {\"LASSO\": \"right\"}\n",
        "    pareto_model_names = set(pareto_models[\"model\"])\n",
        "\n",
        "    for _, row in pareto_frame.sort_values(\"mean_inference_us\").iterrows():\n",
        "        is_optimal = row[\"model\"] in pareto_model_names\n",
        "        xshift, yshift = label_offsets.get(row[\"model\"], (5, 5 if is_optimal else -10))\n",
        "        fig.add_annotation(\n",
        "            x=np.log10(row[\"mean_inference_us\"]),\n",
        "            y=row[\"qlike_plot\"],\n",
        "            text=row[\"plot_label\"],\n",
        "            showarrow=False,\n",
        "            xshift=xshift,\n",
        "            yshift=yshift,\n",
        "            xanchor=label_alignments.get(row[\"model\"], \"left\"),\n",
        "            font=dict(color=\"red\" if is_optimal else \"gray\", size=11),\n",
        "        )\n",
        "\n",
        "    for x_val, color, label in [\n",
        "        (1, \"green\", \"1 μs\"),\n",
        "        (10, \"goldenrod\", \"10 μs\"),\n",
        "        (1000, \"purple\", \"1000 μs\"),\n",
        "    ]:\n",
        "        fig.add_vline(\n",
        "            x=x_val,\n",
        "            line_dash=\"dash\",\n",
        "            line_color=color,\n",
        "            line_width=1.2,\n",
        "            annotation_text=label,\n",
        "            annotation_position=\"top\",\n",
        "            annotation_font_color=color,\n",
        "        )\n",
        "\n",
        "    fig.update_xaxes(\n",
        "        type=\"log\",\n",
        "        title_text=\"Mean inference latency (μs, log scale)\",\n",
        "        showgrid=True,\n",
        "        gridcolor=\"rgba(0,0,0,0.1)\",\n",
        "        range=[\n",
        "            np.log10(max(pareto_frame[\"mean_inference_us\"].min() * 0.6, 0.01)),\n",
        "            np.log10(pareto_frame[\"mean_inference_us\"].max() * 2),\n",
        "        ],\n",
        "    )\n",
        "\n",
        "    fig.update_yaxes(\n",
        "        title_text=\"QLIKE (lower is better)\",\n",
        "        showgrid=True,\n",
        "        gridcolor=\"rgba(0,0,0,0.1)\",\n",
        "        range=[\n",
        "            max(pareto_frame[\"qlike_plot\"].min() - 0.08, 0),\n",
        "            pareto_frame[\"qlike_plot\"].max() + 0.15,\n",
        "        ],\n",
        "    )\n",
        "\n",
        "    fig.update_layout(\n",
        "        title=\"Pareto Frontier: Volatility Model Selection\",\n",
        "        plot_bgcolor=\"white\",\n",
        "        paper_bgcolor=\"white\",\n",
        "        legend=dict(orientation=\"h\", yanchor=\"bottom\", y=1.02, xanchor=\"right\", x=1),\n",
        "        height=500,\n",
        "        font=dict(family=\"Arial\", size=12),\n",
        "        margin=dict(l=60, r=40, t=80, b=60),\n",
        "    )\n",
        "\n",
        "    fig.show()"
      ],
      "id": "fig-pareto-frontier",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "@fig-pareto-frontier shows the Pareto frontier of QLIKE loss against inference latency. The Pareto-optimal set consists of HAR-RV, LASSO, and XGBoost, where no alternative achieves simultaneously lower prediction error and lower latency. HAR-RV occupies the low latency extreme, XGBoost has the lowest QLIKE loss and LASSO provides an intermediate between the two. All remaining models are dominated, meaning at least one Pareto-optimal alternative performs better. Overall, we find a tradeoff between inference latency and accuracy. While XGBoost has the best overall balance between computational efficiency and predictive performance, our Pareto analysis supports that no single model is universally optimal across all evaluation criteria. Hence, model selection should depend on traders' latency tolerance and accuracy requirements.\n",
        "\n",
        "## Part B: Deployment process\n",
        "\n",
        "The final product is deployed as an interactive Streamlit web application, organised into three pages accessible through a fixed top navigation bar: a Model Specification page, an Individual Stock page, and a Universe page for cross-stock comparisons. To keep the tool responsive, all model results are pre-computed and cached during an initial backend run lasting between thirty minutes and four hours depending on models selected and available hardware. Once cached, results load instantly, with the specific backend run displayed to the user to ensure traceability. @fig-individual-stock-widget illustrates the Individual Stock page, where the user selects a stock and time_id to view observed realised volatility alongside forecasts from every model for the final thirty seconds. A clearly marked forecast start line separates the observed period from the forecast horizon, with held-out realised volatility overlaid for direct visual assessment.\n",
        "\n",
        "From a data science perspective, the individual stock view lets a practitioner diagnose where models fail at a granular level, for example, whether a fast linear model like LASSO tracked a volatility spike as closely as XGBoost, or whether GARCH predictions diverged during periods of rapid order book activity. Aggregate win counts and average QLIKE scores alone obscure this stock level and window level variation. From a trader's perspective, this granularity matters because a model which performs well on average may still behave poorly on the specific assets in a trader's portfolio. By surfacing both the universe-level Pareto frontier and per stock diagnostic detail in a single interface, the dashboard gives traders the high-level model selection guidance and the asset specific insight needed to deploy a volatility model with confidence. Give the demo a try yourself below."
      ],
      "id": "b59e166d"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-individual-stock-widget\n",
        "#| fig-cap: Individual stock dashboard view.\n",
        "\n",
        "from back_end.config import DataConfig\n",
        "from back_end.data import list_available_stocks, load_processed_stock\n",
        "from back_end.service import build_prediction_curves\n",
        "\n",
        "\n",
        "REPORT_WIDGET_STOCK_LIMIT = 12\n",
        "REPORT_WIDGET_TIME_LIMIT = 20\n",
        "\n",
        "\n",
        "def stock_sort_key(value: object) -> tuple[int, int, str]:\n",
        "    text = str(value)\n",
        "    if text.startswith(\"stock_\"):\n",
        "        suffix = text.removeprefix(\"stock_\")\n",
        "        if suffix.isdigit():\n",
        "            return (0, int(suffix), text)\n",
        "    return (1, 0, text)\n",
        "\n",
        "\n",
        "def realised_series_from_processed(processed: pd.DataFrame, time_id: int, horizon: int) -> pd.DataFrame:\n",
        "    chunk = processed[processed[\"time_id\"] == time_id].sort_values(\"seconds_in_bucket\").copy()\n",
        "    if chunk.empty:\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    returns = chunk[\"log_price_diff\"].to_numpy(dtype=float) * 10000\n",
        "    seconds = chunk[\"seconds_in_bucket\"].to_numpy(dtype=int)\n",
        "    valid = np.isfinite(returns)\n",
        "    returns = returns[valid]\n",
        "    seconds = seconds[valid]\n",
        "    if len(returns) <= horizon:\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    cutoff_idx = len(returns) - horizon\n",
        "    split_second = int(seconds[cutoff_idx])\n",
        "    rolling_vol = (\n",
        "        pd.Series(returns ** 2)\n",
        "        .rolling(30, min_periods=5)\n",
        "        .mean()\n",
        "        .pow(0.5)\n",
        "        .to_numpy()\n",
        "    )\n",
        "    observed = pd.DataFrame({\n",
        "        \"seconds_in_bucket\": seconds[:cutoff_idx],\n",
        "        \"realized_vol\": rolling_vol[:cutoff_idx],\n",
        "        \"segment\": \"observed\",\n",
        "        \"split_second\": split_second,\n",
        "        \"forecast_horizon\": horizon,\n",
        "    })\n",
        "    heldout = pd.DataFrame({\n",
        "        \"seconds_in_bucket\": seconds[cutoff_idx:],\n",
        "        \"realized_vol\": rolling_vol[cutoff_idx:],\n",
        "        \"segment\": \"heldout_actual\",\n",
        "        \"split_second\": split_second,\n",
        "        \"forecast_horizon\": horizon,\n",
        "    })\n",
        "    return pd.concat([observed, heldout], ignore_index=True).dropna(subset=[\"realized_vol\"])\n",
        "\n",
        "\n",
        "def series_points(frame: pd.DataFrame) -> dict:\n",
        "    return {\n",
        "        \"x\": frame[\"seconds_in_bucket\"].astype(int).tolist(),\n",
        "        \"y\": frame[\"realized_vol\"].round(6).tolist(),\n",
        "    }\n",
        "\n",
        "\n",
        "def curve_points(frame: pd.DataFrame) -> dict:\n",
        "    return {\n",
        "        \"model\": str(frame[\"model\"].iloc[0]),\n",
        "        \"kind\": str(frame[\"prediction_kind\"].iloc[0]),\n",
        "        \"x\": frame[\"seconds_in_bucket\"].astype(int).tolist(),\n",
        "        \"y\": frame[\"pred_vol\"].round(6).tolist(),\n",
        "    }\n",
        "\n",
        "\n",
        "if predictions.empty:\n",
        "    print(\"No cached predictions were available for the individual-stock report widget.\")\n",
        "else:\n",
        "    run_id = RUN_DIR.name if RUN_DIR is not None else \"cached run\"\n",
        "    raw_stocks = set(list_available_stocks(RAW_DATA_DIR))\n",
        "    available_stocks = sorted(\n",
        "        set(predictions[\"stock_id\"].dropna().unique().tolist()).intersection(raw_stocks),\n",
        "        key=stock_sort_key,\n",
        "    )\n",
        "    available_time_ids = [int(value) for value in sorted(predictions[\"time_id\"].dropna().unique())]\n",
        "    if not raw_stocks:\n",
        "        print(f\"No raw stock CSV subset was found in {RAW_DATA_DIR}. The report still renders from cached artifacts, but the individual-stock widget is omitted.\")\n",
        "    elif not available_stocks:\n",
        "        print(\"The raw stock CSV subset does not overlap the cached prediction stock IDs, so the individual-stock widget is omitted.\")\n",
        "    else:\n",
        "        widget_stocks = available_stocks[:REPORT_WIDGET_STOCK_LIMIT]\n",
        "        widget_time_ids = available_time_ids[:REPORT_WIDGET_TIME_LIMIT]\n",
        "        if \"stock_0\" in available_stocks and \"stock_0\" not in widget_stocks:\n",
        "            widget_stocks = [\"stock_0\", *widget_stocks[:-1]]\n",
        "        if 5 in available_time_ids and 5 not in widget_time_ids:\n",
        "            widget_time_ids = [5, *widget_time_ids[:-1]]\n",
        "        widget_time_ids = sorted(set(widget_time_ids))\n",
        "\n",
        "        horizon = int(load_json(RUN_DIR / \"config.json\").get(\"features\", {}).get(\"forecast_horizon\", 30)) if RUN_DIR else 30\n",
        "        data_payload = {}\n",
        "        data_config = DataConfig(source_dir=str(RAW_DATA_DIR))\n",
        "\n",
        "        for stock_id in widget_stocks:\n",
        "            processed = load_processed_stock(stock_id, data_config)\n",
        "            stock_payload = {}\n",
        "            stock_predictions = predictions[predictions[\"stock_id\"] == stock_id]\n",
        "            for time_id in widget_time_ids:\n",
        "                realised = realised_series_from_processed(processed, time_id, horizon)\n",
        "                if realised.empty:\n",
        "                    continue\n",
        "                selected_predictions = stock_predictions[stock_predictions[\"time_id\"] == time_id].reset_index(drop=True)\n",
        "                curves = build_prediction_curves(realised, selected_predictions)\n",
        "                observed = realised[realised[\"segment\"] == \"observed\"]\n",
        "                heldout = realised[realised[\"segment\"] == \"heldout_actual\"]\n",
        "                forecast_curves = []\n",
        "                if not curves.empty and \"model\" in curves.columns:\n",
        "                    forecast_curves = [\n",
        "                        curve_points(frame)\n",
        "                        for _, frame in curves.groupby(\"model\", sort=False)\n",
        "                        if not frame.empty\n",
        "                    ]\n",
        "                stock_payload[str(time_id)] = {\n",
        "                    \"observed\": series_points(observed),\n",
        "                    \"heldout\": series_points(heldout),\n",
        "                    \"splitSecond\": int(realised[\"split_second\"].dropna().iloc[0]),\n",
        "                    \"maxSecond\": int(realised[\"seconds_in_bucket\"].max()),\n",
        "                    \"curves\": forecast_curves,\n",
        "                }\n",
        "            if stock_payload:\n",
        "                data_payload[stock_id] = stock_payload\n",
        "\n",
        "        widget_data = {\n",
        "            \"runId\": run_id,\n",
        "            \"defaultStock\": \"stock_0\" if \"stock_0\" in data_payload else next(iter(data_payload), \"\"),\n",
        "            \"defaultTimeId\": \"5\",\n",
        "            \"stocks\": list(data_payload),\n",
        "            \"series\": data_payload,\n",
        "        }\n",
        "        widget_json = json.dumps(widget_data).replace(\"</\", \"<\\\\/\")\n",
        "\n",
        "        display(HTML(f\"\"\"\n",
        "    <div id=\"individual-stock-report-widget\" class=\"individual-stock-widget\">\n",
        "      <style>\n",
        "        .individual-stock-widget {{\n",
        "          background: #0e1117;\n",
        "          color: #f8fafc;\n",
        "          border-radius: 8px;\n",
        "          padding: 1.2rem 1.35rem 1.4rem;\n",
        "          margin: 1rem 0;\n",
        "          font-family: Arial, sans-serif;\n",
        "        }}\n",
        "        .individual-stock-widget h3 {{\n",
        "          margin: 0 0 1rem;\n",
        "          font-size: 1.45rem;\n",
        "          line-height: 1.2;\n",
        "        }}\n",
        "        .individual-stock-controls {{\n",
        "          display: grid;\n",
        "          grid-template-columns: minmax(0, 3fr) minmax(160px, 1fr);\n",
        "          gap: 1rem;\n",
        "          margin-bottom: 0.75rem;\n",
        "        }}\n",
        "        .individual-stock-control label {{\n",
        "          display: block;\n",
        "          color: #d7dce2;\n",
        "          font-size: 0.78rem;\n",
        "          font-weight: 650;\n",
        "          margin-bottom: 0.45rem;\n",
        "        }}\n",
        "        .individual-stock-control select {{\n",
        "          width: 100%;\n",
        "          background: #262933;\n",
        "          color: #f8fafc;\n",
        "          border: 1px solid #262933;\n",
        "          border-radius: 7px;\n",
        "          padding: 0.62rem 0.75rem;\n",
        "          font-size: 0.9rem;\n",
        "        }}\n",
        "        .individual-stock-caption {{\n",
        "          color: #aab1bd;\n",
        "          font-size: 0.78rem;\n",
        "          margin: 0.4rem 0 1.2rem;\n",
        "        }}\n",
        "        .individual-stock-caption code {{\n",
        "          color: #35b779;\n",
        "          background: transparent;\n",
        "          padding: 0;\n",
        "        }}\n",
        "        .individual-stock-chart-title {{\n",
        "          font-weight: 700;\n",
        "          color: #f8fafc;\n",
        "          margin: 0 0 0.45rem;\n",
        "        }}\n",
        "        .individual-stock-chart-message {{\n",
        "          align-items: center;\n",
        "          color: #aab1bd;\n",
        "          display: flex;\n",
        "          height: 100%;\n",
        "          justify-content: center;\n",
        "          text-align: center;\n",
        "        }}\n",
        "        .individual-stock-note {{\n",
        "          color: #aab1bd;\n",
        "          font-size: 0.75rem;\n",
        "          margin-top: 0.55rem;\n",
        "        }}\n",
        "        @media (max-width: 760px) {{\n",
        "          .individual-stock-controls {{\n",
        "            grid-template-columns: 1fr;\n",
        "          }}\n",
        "        }}\n",
        "      </style>\n",
        "      <h3>Individual Stock</h3>\n",
        "      <div class=\"individual-stock-controls\">\n",
        "        <div class=\"individual-stock-control\">\n",
        "          <label for=\"report-stock-select\">Select stock</label>\n",
        "          <select id=\"report-stock-select\"></select>\n",
        "        </div>\n",
        "        <div class=\"individual-stock-control\">\n",
        "          <label for=\"report-time-select\">Time window (10-min period)</label>\n",
        "          <select id=\"report-time-select\"></select>\n",
        "        </div>\n",
        "      </div>\n",
        "      <div class=\"individual-stock-caption\">Showing backend run <code>{run_id}</code>.</div>\n",
        "      <div id=\"report-chart-title\" class=\"individual-stock-chart-title\"></div>\n",
        "      <div id=\"report-individual-stock-chart\" style=\"width:100%;height:520px;\"></div>\n",
        "      <div class=\"individual-stock-note\">\n",
        "        Report widget embeds {len(widget_stocks)} stocks and {len(widget_time_ids)} time windows to keep the HTML responsive; the Streamlit app supports the full cached run.\n",
        "      </div>\n",
        "      <script src=\"https://cdn.plot.ly/plotly-2.35.2.min.js\"></script>\n",
        "      <script>\n",
        "      (() => {{\n",
        "        const data = {widget_json};\n",
        "        const colors = [\"#4dabf7\", \"#dee2e6\", \"#90be6d\", \"#ffd43b\", \"#ffb703\", \"#f15bb5\", \"#00bbf9\", \"#ffe066\", \"#8ecae6\", \"#fb8500\", \"#9b5de5\"];\n",
        "        const widget = document.getElementById(\"individual-stock-report-widget\");\n",
        "        const stockSelect = widget.querySelector(\"#report-stock-select\");\n",
        "        const timeSelect = widget.querySelector(\"#report-time-select\");\n",
        "        const chartTitle = widget.querySelector(\"#report-chart-title\");\n",
        "        const chart = widget.querySelector(\"#report-individual-stock-chart\");\n",
        "\n",
        "        function stockOrder(value) {{\n",
        "          const match = String(value).match(/^stock_(\\\\d+)$/);\n",
        "          return match ? Number(match[1]) : Number.MAX_SAFE_INTEGER;\n",
        "        }}\n",
        "\n",
        "        function populateStocks() {{\n",
        "          data.stocks.sort((a, b) => stockOrder(a) - stockOrder(b)).forEach((stock) => {{\n",
        "            const option = document.createElement(\"option\");\n",
        "            option.value = stock;\n",
        "            option.textContent = stock;\n",
        "            stockSelect.appendChild(option);\n",
        "          }});\n",
        "          if (data.defaultStock) stockSelect.value = data.defaultStock;\n",
        "        }}\n",
        "\n",
        "        function populateTimes() {{\n",
        "          const stockPayload = data.series[stockSelect.value] || {{}};\n",
        "          const selected = timeSelect.value;\n",
        "          timeSelect.innerHTML = \"\";\n",
        "          Object.keys(stockPayload).map(Number).sort((a, b) => a - b).forEach((timeId) => {{\n",
        "            const option = document.createElement(\"option\");\n",
        "            option.value = String(timeId);\n",
        "            option.textContent = String(timeId);\n",
        "            timeSelect.appendChild(option);\n",
        "          }});\n",
        "          if (stockPayload[selected]) {{\n",
        "            timeSelect.value = selected;\n",
        "          }} else if (stockPayload[data.defaultTimeId]) {{\n",
        "            timeSelect.value = data.defaultTimeId;\n",
        "          }}\n",
        "        }}\n",
        "\n",
        "        function lineTrace(points, name, color, dash = \"solid\", width = 2.4) {{\n",
        "          return {{\n",
        "            x: points.x,\n",
        "            y: points.y,\n",
        "            type: \"scatter\",\n",
        "            mode: \"lines\",\n",
        "            name,\n",
        "            line: {{ color, width, dash }},\n",
        "            hovertemplate: \"Time: %{{x}}s<br>Volatility: %{{y:.6f}}<extra>\" + name + \"</extra>\"\n",
        "          }};\n",
        "        }}\n",
        "\n",
        "        function render() {{\n",
        "          const stock = stockSelect.value;\n",
        "          const timeId = timeSelect.value;\n",
        "          const payload = data.series?.[stock]?.[timeId];\n",
        "          chartTitle.textContent = `Realised Volatility — ${{stock}} · Window ${{timeId}}`;\n",
        "\n",
        "          if (!payload) {{\n",
        "            chart.innerHTML = '<div class=\"individual-stock-chart-message\">No cached data is available for this stock and time window.</div>';\n",
        "            return;\n",
        "          }}\n",
        "          if (!window.Plotly) {{\n",
        "            chart.innerHTML = '<div class=\"individual-stock-chart-message\">The chart library did not load. Reopen the report with an internet connection and refresh.</div>';\n",
        "            return;\n",
        "          }}\n",
        "\n",
        "          const traces = [\n",
        "            lineTrace(payload.observed, \"Observed realised volatility\", colors[0], \"solid\", 2.6),\n",
        "            lineTrace(payload.heldout, \"Held-out realised volatility\", colors[1], \"dot\", 2.4),\n",
        "          ];\n",
        "          payload.curves.forEach((curve, index) => {{\n",
        "            traces.push(lineTrace(\n",
        "              {{ x: curve.x, y: curve.y }},\n",
        "              `${{curve.model}} forecast`,\n",
        "              colors[(index + 2) % colors.length],\n",
        "              curve.kind === \"garch_path\" ? \"solid\" : \"dash\",\n",
        "              2.1\n",
        "            ));\n",
        "          }});\n",
        "\n",
        "          const maxY = Math.max(\n",
        "            0.001,\n",
        "            ...traces.flatMap((trace) => trace.y || []).filter((value) => Number.isFinite(value))\n",
        "          );\n",
        "          const layout = {{\n",
        "            height: 520,\n",
        "            margin: {{ t: 82, r: 14, b: 52, l: 64 }},\n",
        "            paper_bgcolor: \"#0e1117\",\n",
        "            plot_bgcolor: \"#141922\",\n",
        "            font: {{ color: \"#dce2ea\", family: \"Arial, sans-serif\", size: 12 }},\n",
        "            xaxis: {{\n",
        "              title: {{ text: \"Time (seconds)\" }},\n",
        "              range: [0, 600],\n",
        "              tickvals: [0, 60, 120, 180, 240, 300, 360, 420, 480, 540, 600],\n",
        "              ticktext: [\"0m\", \"1m\", \"2m\", \"3m\", \"4m\", \"5m\", \"6m\", \"7m\", \"8m\", \"9m\", \"10m\"],\n",
        "              gridcolor: \"rgba(210, 220, 230, 0.16)\",\n",
        "              zerolinecolor: \"rgba(210, 220, 230, 0.18)\"\n",
        "            }},\n",
        "            yaxis: {{\n",
        "              title: {{ text: \"Realised Volatility\" }},\n",
        "              range: [0, maxY * 1.08],\n",
        "              tickformat: \".4f\",\n",
        "              gridcolor: \"rgba(210, 220, 230, 0.16)\",\n",
        "              zerolinecolor: \"rgba(210, 220, 230, 0.18)\"\n",
        "            }},\n",
        "            legend: {{\n",
        "              orientation: \"h\",\n",
        "              yanchor: \"bottom\",\n",
        "              y: 1.08,\n",
        "              xanchor: \"left\",\n",
        "              x: 0,\n",
        "              font: {{ size: 11 }}\n",
        "            }},\n",
        "            hovermode: \"x unified\",\n",
        "            shapes: [\n",
        "              {{\n",
        "                type: \"rect\",\n",
        "                xref: \"x\",\n",
        "                yref: \"paper\",\n",
        "                x0: 0,\n",
        "                x1: payload.splitSecond,\n",
        "                y0: 0,\n",
        "                y1: 1,\n",
        "                fillcolor: \"rgba(77, 171, 247, 0.05)\",\n",
        "                line: {{ width: 0 }},\n",
        "                layer: \"below\"\n",
        "              }},\n",
        "              {{\n",
        "                type: \"rect\",\n",
        "                xref: \"x\",\n",
        "                yref: \"paper\",\n",
        "                x0: payload.splitSecond,\n",
        "                x1: payload.maxSecond,\n",
        "                y0: 0,\n",
        "                y1: 1,\n",
        "                fillcolor: \"rgba(251, 133, 0, 0.08)\",\n",
        "                line: {{ width: 0 }},\n",
        "                layer: \"below\"\n",
        "              }},\n",
        "              {{\n",
        "                type: \"line\",\n",
        "                xref: \"x\",\n",
        "                yref: \"paper\",\n",
        "                x0: payload.splitSecond,\n",
        "                x1: payload.splitSecond,\n",
        "                y0: 0,\n",
        "                y1: 1,\n",
        "                line: {{ color: \"#adb5bd\", width: 1.5, dash: \"dot\" }}\n",
        "              }}\n",
        "            ],\n",
        "            annotations: [{{\n",
        "              x: payload.splitSecond,\n",
        "              y: 1,\n",
        "              xref: \"x\",\n",
        "              yref: \"paper\",\n",
        "              text: \"Forecast start\",\n",
        "              showarrow: false,\n",
        "              xanchor: \"left\",\n",
        "              yanchor: \"bottom\",\n",
        "              font: {{ color: \"#adb5bd\", size: 11 }}\n",
        "            }}]\n",
        "          }};\n",
        "\n",
        "          Plotly.react(chart, traces, layout, {{ responsive: true, displayModeBar: false }});\n",
        "        }}\n",
        "\n",
        "        function renderWhenPlotlyIsReady() {{\n",
        "          if (window.Plotly) {{\n",
        "            render();\n",
        "          }} else {{\n",
        "            window.setTimeout(render, 1200);\n",
        "          }}\n",
        "        }}\n",
        "\n",
        "        populateStocks();\n",
        "        populateTimes();\n",
        "        stockSelect.addEventListener(\"change\", () => {{\n",
        "          populateTimes();\n",
        "          renderWhenPlotlyIsReady();\n",
        "        }});\n",
        "        timeSelect.addEventListener(\"change\", renderWhenPlotlyIsReady);\n",
        "        renderWhenPlotlyIsReady();\n",
        "      }})();\n",
        "      </script>\n",
        "    </div>\n",
        "    \"\"\"))"
