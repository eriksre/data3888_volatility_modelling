        "            if (!sidebar || window.document.querySelector(\".night-mode-control\")) {\n",
        "              return;\n",
        "            }\n",
        "\n",
        "            const control = window.document.createElement(\"div\");\n",
        "            control.className = \"night-mode-control\";\n",
        "            control.innerHTML = `\n",
        "              <button type=\"button\" class=\"night-mode-toggle quarto-color-scheme-toggle\" aria-label=\"Toggle night mode\">\n",
        "                <span class=\"night-mode-label\">Night mode</span>\n",
        "                <span class=\"night-mode-switch\" aria-hidden=\"true\">\n",
        "                  <span class=\"night-mode-symbol\"></span>\n",
        "                  <span class=\"night-mode-knob\"></span>\n",
        "                </span>\n",
        "              </button>\n",
        "            `;\n",
        "            sidebar.prepend(control);\n",
        "\n",
        "            const toggle = control.querySelector(\".night-mode-toggle\");\n",
        "            const syncToggle = () => {\n",
        "              const isDark = window.document.body.classList.contains(\"quarto-dark\");\n",
        "              toggle.classList.toggle(\"alternate\", isDark);\n",
        "              toggle.setAttribute(\"aria-pressed\", String(isDark));\n",
        "            };\n",
        "\n",
        "            toggle.addEventListener(\"click\", () => {\n",
        "              window.quartoToggleColorScheme();\n",
        "              syncToggle();\n",
        "            });\n",
        "\n",
        "            syncToggle();\n",
        "            new MutationObserver(syncToggle).observe(window.document.body, {\n",
        "              attributes: true,\n",
        "              attributeFilter: [\"class\"],\n",
        "            });\n",
        "          }, 0);\n",
        "        });\n",
        "        </script>\n",
