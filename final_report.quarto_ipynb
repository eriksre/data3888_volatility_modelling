        "#| label: fig-appendix-individual-static\n",
        "#| fig-cap: Static individual-stock forecast example from the cached product run.\n",
        "\n",
        "from back_end.config import DataConfig\n",
        "from back_end.data import list_available_stocks, load_processed_stock\n",
        "from back_end.service import build_prediction_curves\n",
        "\n",
        "\n",
        "if predictions.empty:\n",
        "    print(\"No cached predictions were available for the static individual-stock example.\")\n",
        "else:\n",
        "    raw_stocks = set(list_available_stocks(RAW_DATA_DIR))\n",
        "    prediction_stocks = set(predictions[\"stock_id\"].dropna().unique())\n",
        "    available_stocks = sorted(raw_stocks.intersection(prediction_stocks), key=stock_sort_key)\n",
        "\n",
        "    if not raw_stocks:\n",
        "        print(f\"No raw stock CSV subset was found in {RAW_DATA_DIR}. The static individual-stock example is omitted.\")\n",
        "    elif not available_stocks:\n",
        "        print(\"The raw stock CSV subset does not overlap the cached prediction stock IDs, so the static individual-stock example is omitted.\")\n",
        "    else:\n",
        "        example_stock = \"stock_10\" if \"stock_10\" in available_stocks else available_stocks[0]\n",
        "        available_times = sorted(predictions.loc[predictions[\"stock_id\"] == example_stock, \"time_id\"].dropna().unique())\n",
        "        example_time = 5 if 5 in available_times else int(available_times[0])\n",
        "        horizon = int(feature_config.get(\"forecast_horizon\", 30))\n",
        "\n",
        "        processed = load_processed_stock(example_stock, DataConfig(source_dir=str(RAW_DATA_DIR)))\n",
        "        realised = realised_series_from_processed(processed, example_time, horizon)\n",
        "        selected_predictions = predictions[\n",
        "            (predictions[\"stock_id\"] == example_stock)\n",
        "            & (predictions[\"time_id\"] == example_time)\n",
        "        ].reset_index(drop=True)\n",
        "        selected_predictions = selected_predictions[\n",
        "            selected_predictions[\"model\"].isin([\"HAR-RV\", \"LASSO\", \"XGBoost\", \"GJR-GARCH(1,1)\"])\n",
        "        ].copy()\n",
        "        curves = build_prediction_curves(realised, selected_predictions)\n",
        "\n",
        "        if realised.empty or curves.empty:\n",
        "            print(\"No realised series or forecast curves were available for the selected stock/time_id.\")\n",
        "        else:\n",
        "            fig, ax = plt.subplots(figsize=(12, 5.8))\n",
        "            observed = realised[realised[\"segment\"] == \"observed\"]\n",
        "            heldout = realised[realised[\"segment\"] == \"heldout_actual\"]\n",
        "            split_second = int(realised[\"split_second\"].dropna().iloc[0])\n",
        "\n",
        "            ax.plot(\n",
        "                observed[\"seconds_in_bucket\"],\n",
        "                observed[\"realized_vol\"],\n",
        "                color=\"#4dabf7\",\n",
        "                linewidth=2.2,\n",
        "                label=\"Observed realised volatility\",\n",
        "            )\n",
        "            ax.plot(\n",
        "                heldout[\"seconds_in_bucket\"],\n",
        "                heldout[\"realized_vol\"],\n",
        "                color=\"#495057\",\n",
        "                linewidth=2.0,\n",
        "                linestyle=\":\",\n",
        "                label=\"Held-out realised volatility\",\n",
        "            )\n",
        "\n",
        "            palette = {\n",
        "                \"HAR-RV\": \"#2f9e44\",\n",
        "                \"LASSO\": \"#845ef7\",\n",
        "                \"XGBoost\": \"#f59f00\",\n",
        "                \"GJR-GARCH(1,1)\": \"#e03131\",\n",
        "            }\n",
        "            for model, frame in curves.groupby(\"model\", sort=False):\n",
        "                frame = frame.sort_values(\"seconds_in_bucket\")\n",
        "                ax.plot(\n",
        "                    frame[\"seconds_in_bucket\"],\n",
        "                    frame[\"pred_vol\"],\n",
        "                    linewidth=1.8,\n",
        "                    linestyle=\"--\" if frame[\"prediction_kind\"].iloc[0] != \"garch_path\" else \"-\",\n",
        "                    color=palette.get(model, \"#6c757d\"),\n",
        "                    label=f\"{model} forecast\",\n",
        "                )\n",
        "\n",
        "            ax.axvline(split_second, color=\"#868e96\", linewidth=1.4, linestyle=\"--\")\n",
        "            ax.text(split_second + 3, ax.get_ylim()[1] * 0.96, \"Forecast start\", color=\"#868e96\", fontsize=9, va=\"top\")\n",
        "            ax.set_title(f\"Individual stock view: {stock_label(example_stock)} / time_id {example_time}\", fontweight=\"bold\", loc=\"left\")\n",
        "            ax.set_xlabel(\"Seconds in bucket\")\n",
        "            ax.set_ylabel(\"Realised volatility\")\n",
        "            ax.grid(alpha=0.22)\n",
        "            ax.legend(frameon=False, ncol=2, fontsize=8)\n",
        "            ax.spines[\"top\"].set_visible(False)\n",
        "            ax.spines[\"right\"].set_visible(False)\n",
        "            plt.tight_layout()\n",
