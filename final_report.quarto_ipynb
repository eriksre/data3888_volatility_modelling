        "---\n",
        "title: \"DATA3888 Group 6 - Volatility Modelling\"\n",
        "format:\n",
        "  html:\n",
        "    toc: true\n",
        "    toc-location: left\n",
        "    toc-depth: 2\n",
        "    number-sections: false\n",
        "    code-fold: true\n",
