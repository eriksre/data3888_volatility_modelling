        "#| label: fig-appendix-feature-importance\n",
        "#| fig-cap: Largest average PCA-component importances across fitted models.\n",
        "\n",
        "if feature_importance.empty:\n",
        "    print(\"No cached feature importance data was available.\")\n",
        "else:\n",
        "    importance = (\n",
        "        feature_importance.groupby([\"model\", \"feature\"], as_index=False)[\"importance\"]\n",
        "        .mean()\n",
        "        .sort_values(\"importance\", ascending=False)\n",
        "    )\n",
        "    top_features = importance.groupby(\"feature\", as_index=False)[\"importance\"].sum()\n",
        "    top_features = top_features.nlargest(10, \"importance\")[\"feature\"].tolist()\n",
        "    plot_importance = importance[importance[\"feature\"].isin(top_features)].copy()\n",
        "    plot_importance = plot_importance.pivot_table(\n",
        "        index=\"feature\",\n",
        "        columns=\"model\",\n",
        "        values=\"importance\",\n",
        "        aggfunc=\"mean\",\n",
        "        fill_value=0,\n",
        "    )\n",
        "    plot_importance = plot_importance.loc[top_features]\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(11, 5.8))\n",
        "    plot_importance.plot(kind=\"bar\", ax=ax, width=0.82)\n",
