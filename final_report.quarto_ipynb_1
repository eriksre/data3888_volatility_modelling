       "        const colors = [\"#4dabf7\", \"#dee2e6\", \"#90be6d\", \"#ffd43b\", \"#ffb703\", \"#f15bb5\", \"#00bbf9\", \"#ffe066\", \"#8ecae6\", \"#fb8500\", \"#9b5de5\"];\n",
       "        const widget = document.getElementById(\"individual-stock-report-widget\");\n",
       "        const stockSelect = widget.querySelector(\"#report-stock-select\");\n",
       "        const timeSelect = widget.querySelector(\"#report-time-select\");\n",
       "        const chartTitle = widget.querySelector(\"#report-chart-title\");\n",
       "        const chart = widget.querySelector(\"#report-individual-stock-chart\");\n",
       "\n",
       "        function stockOrder(value) {\n",
       "          const match = String(value).match(/^stock_(\\d+)$/);\n",
       "          return match ? Number(match[1]) : Number.MAX_SAFE_INTEGER;\n",
       "        }\n",
       "\n",
       "        function populateStocks() {\n",
       "          data.stocks.sort((a, b) => stockOrder(a) - stockOrder(b)).forEach((stock) => {\n",
       "            const option = document.createElement(\"option\");\n",
       "            option.value = stock;\n",
       "            option.textContent = stock;\n",
       "            stockSelect.appendChild(option);\n",
       "          });\n",
       "          if (data.defaultStock) stockSelect.value = data.defaultStock;\n",
       "        }\n",
       "\n",
       "        function populateTimes() {\n",
       "          const stockPayload = data.series[stockSelect.value] || {};\n",
       "          const selected = timeSelect.value;\n",
       "          timeSelect.innerHTML = \"\";\n",
       "          Object.keys(stockPayload).map(Number).sort((a, b) => a - b).forEach((timeId) => {\n",
       "            const option = document.createElement(\"option\");\n",
       "            option.value = String(timeId);\n",
       "            option.textContent = String(timeId);\n",
       "            timeSelect.appendChild(option);\n",
       "          });\n",
       "          if (stockPayload[selected]) {\n",
       "            timeSelect.value = selected;\n",
       "          } else if (stockPayload[data.defaultTimeId]) {\n",
       "            timeSelect.value = data.defaultTimeId;\n",
       "          }\n",
       "        }\n",
       "\n",
       "        function lineTrace(points, name, color, dash = \"solid\", width = 2.4) {\n",
       "          return {\n",
       "            x: points.x,\n",
       "            y: points.y,\n",
       "            type: \"scatter\",\n",
       "            mode: \"lines\",\n",
       "            name,\n",
       "            line: { color, width, dash },\n",
       "            hovertemplate: \"Time: %{x}s<br>Volatility: %{y:.6f}<extra>\" + name + \"</extra>\"\n",
       "          };\n",
       "        }\n",
       "\n",
       "        function render() {\n",
       "          const stock = stockSelect.value;\n",
       "          const timeId = timeSelect.value;\n",
       "          const payload = data.series?.[stock]?.[timeId];\n",
       "          chartTitle.textContent = `Realised Volatility — ${stock} · Window ${timeId}`;\n",
       "\n",
       "          if (!payload) {\n",
       "            chart.innerHTML = '<div class=\"individual-stock-chart-message\">No cached data is available for this stock and time window.</div>';\n",
       "            return;\n",
       "          }\n",
       "          if (!window.Plotly) {\n",
       "            chart.innerHTML = '<div class=\"individual-stock-chart-message\">The chart library did not load. Reopen the report with an internet connection and refresh.</div>';\n",
       "            return;\n",
       "          }\n",
       "\n",
       "          const traces = [\n",
       "            lineTrace(payload.observed, \"Observed realised volatility\", colors[0], \"solid\", 2.6),\n",
       "            lineTrace(payload.heldout, \"Held-out realised volatility\", colors[1], \"dot\", 2.4),\n",
       "          ];\n",
       "          payload.curves.forEach((curve, index) => {\n",
       "            traces.push(lineTrace(\n",
       "              { x: curve.x, y: curve.y },\n",
       "              `${curve.model} forecast`,\n",
       "              colors[(index + 2) % colors.length],\n",
       "              curve.kind === \"garch_path\" ? \"solid\" : \"dash\",\n",
       "              2.1\n",
       "            ));\n",
       "          });\n",
       "\n",
       "          const maxY = Math.max(\n",
       "            0.001,\n",
       "            ...traces.flatMap((trace) => trace.y || []).filter((value) => Number.isFinite(value))\n",
       "          );\n",
       "          const layout = {\n",
       "            height: 520,\n",
       "            margin: { t: 82, r: 14, b: 52, l: 64 },\n",
       "            paper_bgcolor: \"#0e1117\",\n",
       "            plot_bgcolor: \"#141922\",\n",
       "            font: { color: \"#dce2ea\", family: \"Arial, sans-serif\", size: 12 },\n",
       "            xaxis: {\n",
       "              title: { text: \"Time (seconds)\" },\n",
       "              range: [0, 600],\n",
       "              tickvals: [0, 60, 120, 180, 240, 300, 360, 420, 480, 540, 600],\n",
       "              ticktext: [\"0m\", \"1m\", \"2m\", \"3m\", \"4m\", \"5m\", \"6m\", \"7m\", \"8m\", \"9m\", \"10m\"],\n",
       "              gridcolor: \"rgba(210, 220, 230, 0.16)\",\n",
       "              zerolinecolor: \"rgba(210, 220, 230, 0.18)\"\n",
       "            },\n",
       "            yaxis: {\n",
       "              title: { text: \"Realised Volatility\" },\n",
       "              range: [0, maxY * 1.08],\n",
       "              tickformat: \".4f\",\n",
       "              gridcolor: \"rgba(210, 220, 230, 0.16)\",\n",
       "              zerolinecolor: \"rgba(210, 220, 230, 0.18)\"\n",
       "            },\n",
       "            legend: {\n",
       "              orientation: \"h\",\n",
       "              yanchor: \"bottom\",\n",
       "              y: 1.08,\n",
       "              xanchor: \"left\",\n",
       "              x: 0,\n",
       "              font: { size: 11 }\n",
       "            },\n",
       "            hovermode: \"x unified\",\n",
       "            shapes: [\n",
       "              {\n",
       "                type: \"rect\",\n",
       "                xref: \"x\",\n",
       "                yref: \"paper\",\n",
       "                x0: 0,\n",
       "                x1: payload.splitSecond,\n",
       "                y0: 0,\n",
       "                y1: 1,\n",
       "                fillcolor: \"rgba(77, 171, 247, 0.05)\",\n",
       "                line: { width: 0 },\n",
       "                layer: \"below\"\n",
       "              },\n",
       "              {\n",
       "                type: \"rect\",\n",
       "                xref: \"x\",\n",
       "                yref: \"paper\",\n",
       "                x0: payload.splitSecond,\n",
       "                x1: payload.maxSecond,\n",
       "                y0: 0,\n",
       "                y1: 1,\n",
       "                fillcolor: \"rgba(251, 133, 0, 0.08)\",\n",
       "                line: { width: 0 },\n",
       "                layer: \"below\"\n",
       "              },\n",
       "              {\n",
       "                type: \"line\",\n",
       "                xref: \"x\",\n",
       "                yref: \"paper\",\n",
       "                x0: payload.splitSecond,\n",
       "                x1: payload.splitSecond,\n",
       "                y0: 0,\n",
       "                y1: 1,\n",
       "                line: { color: \"#adb5bd\", width: 1.5, dash: \"dot\" }\n",
       "              }\n",
       "            ],\n",
       "            annotations: [{\n",
       "              x: payload.splitSecond,\n",
       "              y: 1,\n",
       "              xref: \"x\",\n",
       "              yref: \"paper\",\n",
       "              text: \"Forecast start\",\n",
       "              showarrow: false,\n",
       "              xanchor: \"left\",\n",
       "              yanchor: \"bottom\",\n",
       "              font: { color: \"#adb5bd\", size: 11 }\n",
       "            }]\n",
       "          };\n",
       "\n",
       "          Plotly.react(chart, traces, layout, { responsive: true, displayModeBar: false });\n",
       "        }\n",
       "\n",
       "        function renderWhenPlotlyIsReady() {\n",
       "          if (window.Plotly) {\n",
       "            render();\n",
       "          } else {\n",
       "            window.setTimeout(render, 1200);\n",
       "          }\n",
       "        }\n",
       "\n",
       "        populateStocks();\n",
       "        populateTimes();\n",
       "        stockSelect.addEventListener(\"change\", () => {\n",
       "          populateTimes();\n",
       "          renderWhenPlotlyIsReady();\n",
       "        });\n",
       "        timeSelect.addEventListener(\"change\", renderWhenPlotlyIsReady);\n",
       "        renderWhenPlotlyIsReady();\n",
       "      })();\n",
       "      </script>\n",
       "    </div>\n",
       "    "
