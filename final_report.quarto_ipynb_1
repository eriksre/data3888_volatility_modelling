    "#| label: fig-pca-cumulative-variance\n",
    "#| fig-cap: Cumulative PCA variance.\n",
    "\n",
    "pca_variance = build_pca_variance_explained(load_feature_cache(), FeatureConfig(), 20)\n",
    "\n",
    "if pca_variance.empty:\n",
    "    print(\"No cached feature data was available for the PCA cumulative variance figure.\")\n",
