    "\n",
    "\n",
    "def stock_sort_key(value: object) -> tuple[int, int, str]:\n",
    "    text = str(value)\n",
    "    if text.startswith(\"stock_\"):\n",
    "        suffix = text.removeprefix(\"stock_\")\n",
    "        if suffix.isdigit():\n",
    "            return (0, int(suffix), text)\n",
    "    return (1, 0, text)\n",
    "\n",
    "\n",
    "def realised_series_from_processed(processed: pd.DataFrame, time_id: int, horizon: int) -> pd.DataFrame:\n",
    "    chunk = processed[processed[\"time_id\"] == time_id].sort_values(\"seconds_in_bucket\").copy()\n",
    "    if chunk.empty:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    returns = chunk[\"log_price_diff\"].to_numpy(dtype=float) * 10000\n",
    "    seconds = chunk[\"seconds_in_bucket\"].to_numpy(dtype=int)\n",
    "    valid = np.isfinite(returns)\n",
    "    returns = returns[valid]\n",
    "    seconds = seconds[valid]\n",
    "    if len(returns) <= horizon:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    cutoff_idx = len(returns) - horizon\n",
    "    split_second = int(seconds[cutoff_idx])\n",
    "    rolling_vol = (\n",
    "        pd.Series(returns ** 2)\n",
    "        .rolling(30, min_periods=5)\n",
    "        .mean()\n",
    "        .pow(0.5)\n",
    "        .to_numpy()\n",
    "    )\n",
    "    observed = pd.DataFrame({\n",
    "        \"seconds_in_bucket\": seconds[:cutoff_idx],\n",
    "        \"realized_vol\": rolling_vol[:cutoff_idx],\n",
    "        \"segment\": \"observed\",\n",
    "        \"split_second\": split_second,\n",
    "        \"forecast_horizon\": horizon,\n",
    "    })\n",
    "    heldout = pd.DataFrame({\n",
    "        \"seconds_in_bucket\": seconds[cutoff_idx:],\n",
    "        \"realized_vol\": rolling_vol[cutoff_idx:],\n",
    "        \"segment\": \"heldout_actual\",\n",
    "        \"split_second\": split_second,\n",
    "        \"forecast_horizon\": horizon,\n",
    "    })\n",
    "    return pd.concat([observed, heldout], ignore_index=True).dropna(subset=[\"realized_vol\"])\n",
    "\n",
    "\n",
    "def series_points(frame: pd.DataFrame) -> dict:\n",
    "    return {\n",
    "        \"x\": frame[\"seconds_in_bucket\"].astype(int).tolist(),\n",
    "        \"y\": frame[\"realized_vol\"].round(6).tolist(),\n",
    "    }\n",
    "\n",
    "\n",
    "def curve_points(frame: pd.DataFrame) -> dict:\n",
    "    return {\n",
    "        \"model\": str(frame[\"model\"].iloc[0]),\n",
    "        \"kind\": str(frame[\"prediction_kind\"].iloc[0]),\n",
    "        \"x\": frame[\"seconds_in_bucket\"].astype(int).tolist(),\n",
    "        \"y\": frame[\"pred_vol\"].round(6).tolist(),\n",
    "    }\n",
    "\n",
