    "#| label: setup\n",
    "\n",
    "from pathlib import Path\n",
    "import json\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from IPython.display import HTML, display\n",
    "\n",
    "from back_end.config import ARTIFACTS_DIR, FeatureConfig, INDIVIDUAL_BOOK_DIR, ROOT_DIR\n",
    "from back_end.universe import build_model_comparison\n",
    "from back_end.universe import build_pca_variance_explained\n",
    "\n",
    "PROJECT_ROOT = ROOT_DIR\n",
    "RAW_DATA_DIR = INDIVIDUAL_BOOK_DIR\n",
    "\n",
    "\n",
    "def artifact_path(*parts: str) -> Path:\n",
    "    return ARTIFACTS_DIR.joinpath(*parts)\n",
    "\n",
    "\n",
    "RUNS_DIR = artifact_path(\"runs\")\n",
    "FEATURE_CACHE_PATH = artifact_path(\"feature_cache\", \"features_all_stocks.parquet\")\n",
    "FEATURE_CACHE_MANIFEST_PATH = artifact_path(\"feature_cache\", \"manifest.json\")\n",
    "\n",
    "\n",
    "def latest_run_dir() -> Path | None:\n",
    "    if not RUNS_DIR.exists():\n",
    "        return None\n",
    "    run_dirs = sorted([path for path in RUNS_DIR.iterdir() if path.is_dir()], reverse=True)\n",
    "    return run_dirs[0] if run_dirs else None\n",
    "\n",
    "\n",
    "RUN_DIR = latest_run_dir()\n",
    "\n",
    "\n",
    "def load_artifact(name: str) -> pd.DataFrame:\n",
    "    if RUN_DIR is None:\n",
    "        return pd.DataFrame()\n",
    "    path = RUN_DIR / name\n",
    "    if not path.exists():\n",
    "        return pd.DataFrame()\n",
    "    return pd.read_parquet(path)\n",
    "\n",
    "\n",
    "def load_feature_targets() -> pd.DataFrame:\n",
    "    if not FEATURE_CACHE_PATH.exists():\n",
    "        return pd.DataFrame()\n",
    "    return pd.read_parquet(\n",
    "        FEATURE_CACHE_PATH,\n",
    "        columns=[\"stock_id\", \"time_id\", \"target_var\", \"target_vol\"],\n",
    "    )\n",
    "\n",
    "\n",
    "def load_feature_cache() -> pd.DataFrame:\n",
    "    if not FEATURE_CACHE_PATH.exists():\n",
    "        return pd.DataFrame()\n",
    "    return pd.read_parquet(FEATURE_CACHE_PATH)\n",
    "\n",
    "\n",
    "def load_json(path: Path) -> dict:\n",
    "    if not path.exists():\n",
    "        return {}\n",
    "    return json.loads(path.read_text())\n",
    "\n",
    "\n",
    "metrics = load_artifact(\"metrics.parquet\")\n",
    "predictions = load_artifact(\"predictions.parquet\")\n",
    "feature_importance = load_artifact(\"feature_importance.parquet\")\n",
    "universe_summary = load_artifact(\"universe_summary.parquet\")\n",
    "stock_similarity = load_artifact(\"stock_similarity.parquet\")\n",
    "feature_targets = load_feature_targets()\n",
    "feature_cache_manifest = load_json(FEATURE_CACHE_MANIFEST_PATH)\n",
    "\n",
    "\n",
    "def model_summary_frame(metrics_df: pd.DataFrame, predictions_df: pd.DataFrame) -> pd.DataFrame:\n",
    "    if metrics_df.empty or predictions_df.empty:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    metric_cols = [\"mse\", \"rmse\", \"mae\", \"mape\", \"rmspe\", \"qlike\", \"pearson_r\"]\n",
    "    available_metrics = [col for col in metric_cols if col in metrics_df.columns]\n",
    "    overall = metrics_df.copy()\n",
    "    if \"fold\" in overall.columns:\n",
    "        overall = overall[overall[\"fold\"] == 0].copy()\n",
    "\n",
    "    summary = overall[[\"model\", *available_metrics]].copy()\n",
    "    latency = (\n",
    "        predictions_df.groupby(\"model\", as_index=False)\n",
    "        .agg(\n",
    "            mean_inference_us=(\"inference_ms\", lambda values: values.mean() * 1000),\n",
    "            n_predictions=(\"model\", \"size\"),\n",
    "        )\n",
    "    )\n",
    "    return summary.merge(latency, on=\"model\", how=\"left\")\n",
    "\n",
    "\n",
    "def cached_model_comparison_table(metrics_df: pd.DataFrame, predictions_df: pd.DataFrame) -> pd.DataFrame:\n",
    "    columns = [\n",
    "        \"Model\",\n",
    "        \"Mean inference (μs)\",\n",
    "        \"RMSE model wins\",\n",
    "        \"↓ QLIKE model wins\",\n",
    "        \"RMSE\",\n",
    "        \"QLIKE\",\n",
    "        \"MAE\",\n",
    "        \"MSE\",\n",
    "    ]\n",
    "    if metrics_df.empty and predictions_df.empty:\n",
    "        return pd.DataFrame(columns=columns)\n",
    "\n",
    "    comparison = build_model_comparison(predictions_df, metrics_df)\n",
    "    if comparison.empty:\n",
    "        return pd.DataFrame(columns=columns)\n",
    "\n",
    "    table = comparison[\n",
    "        [\n",
    "            \"model\",\n",
    "            \"mean_inference_ms\",\n",
    "            \"best_stocks_rmse\",\n",
    "            \"best_stocks_qlike\",\n",
    "            \"rmse\",\n",
    "            \"qlike\",\n",
    "            \"mae\",\n",
    "            \"mse\",\n",
    "        ]\n",
    "    ].copy()\n",
    "    table[\"mean_inference_ms\"] = table[\"mean_inference_ms\"] * 1000\n",
    "    table = table.rename(\n",
    "        columns={\n",
    "            \"model\": \"Model\",\n",
    "            \"mean_inference_ms\": \"Mean inference (μs)\",\n",
    "            \"best_stocks_rmse\": \"RMSE model wins\",\n",
    "            \"best_stocks_qlike\": \"↓ QLIKE model wins\",\n",
    "            \"rmse\": \"RMSE\",\n",
    "            \"qlike\": \"QLIKE\",\n",
    "            \"mae\": \"MAE\",\n",
    "            \"mse\": \"MSE\",\n",
    "        }\n",
    "    )\n",
    "    return table.sort_values(\n",
    "        [\"↓ QLIKE model wins\", \"RMSE\", \"Model\"],\n",
    "        ascending=[False, True, True],\n",
    "        na_position=\"last\",\n",
    "    ).reset_index(drop=True)\n",
    "\n",
    "\n",
    "def format_report_table(frame: pd.DataFrame) -> pd.DataFrame:\n",
    "    formatted = frame.copy()\n",
    "    integer_cols = [\"RMSE model wins\", \"↓ QLIKE model wins\"]\n",
    "    numeric_cols = [col for col in formatted.columns if col not in [\"Model\", *integer_cols]]\n",
    "    for col in integer_cols:\n",
    "        if col in formatted.columns:\n",
    "            formatted[col] = formatted[col].map(lambda value: \"\" if pd.isna(value) else f\"{int(value)}\")\n",
    "    for col in numeric_cols:\n",
    "        formatted[col] = formatted[col].map(lambda value: \"\" if pd.isna(value) else f\"{float(value):.3f}\")\n",
    "    return formatted\n",
    "\n",
    "\n",
    "def pareto_optimal_mask(frame: pd.DataFrame, x_col: str, y_col: str) -> pd.Series:\n",
    "    mask = []\n",
    "    for _, row in frame.iterrows():\n",
    "        dominated = (\n",
    "            (frame[x_col] <= row[x_col])\n",
    "            & (frame[y_col] <= row[y_col])\n",
    "            & ((frame[x_col] < row[x_col]) | (frame[y_col] < row[y_col]))\n",
    "        ).any()\n",
    "        mask.append(not dominated)\n",
    "    return pd.Series(mask, index=frame.index)\n",
    "\n",
    "\n",
    "def stock_label(stock_id: str) -> str:\n",
    "    text = str(stock_id)\n",
    "    if text.startswith(\"stock_\"):\n",
    "        text = text.removeprefix(\"stock_\")\n",
    "    try:\n",
    "        return f\"Stock {int(text)}\"\n",
    "    except ValueError:\n",
    "        return str(stock_id)"
   ]
