    "#| label: fig-pareto-frontier\n",
    "#| fig-cap: Accuracy-latency Pareto frontier.\n",
    "\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "model_summary = model_summary_frame(metrics, predictions)\n",
    "pareto_frame = model_summary.dropna(subset=[\"model\", \"mean_inference_us\", \"qlike\"]).copy()\n",
    "pareto_frame = pareto_frame[pareto_frame[\"mean_inference_us\"] > 0].copy()\n",
    "\n",
    "if pareto_frame.empty:\n",
    "    print(\"No cached model metrics were available for the Pareto frontier.\")\n",
    "else:\n",
    "    optimal = pareto_optimal_mask(pareto_frame, \"mean_inference_us\", \"qlike\")\n",
    "\n",
    "    q1, q3 = pareto_frame[\"qlike\"].quantile([0.25, 0.75])\n",
    "    iqr = q3 - q1\n",
    "    qlike_cap = max(q3 + 1.5 * iqr, pareto_frame[\"qlike\"].median())\n",
    "    qlike_cap = min(qlike_cap, pareto_frame[\"qlike\"].max())\n",
    "    pareto_frame[\"qlike_plot\"] = pareto_frame[\"qlike\"].clip(upper=qlike_cap)\n",
    "    pareto_frame[\"qlike_clipped\"] = pareto_frame[\"qlike\"] > qlike_cap\n",
    "    pareto_frame[\"plot_label\"] = pareto_frame.apply(\n",
    "        lambda row: f\"{row['model']} ({row['qlike']:.2f})\"\n",
    "        if row[\"qlike_clipped\"]\n",
    "        else row[\"model\"],\n",
    "        axis=1,\n",
    "    )\n",
    "\n",
    "    pareto_models = pareto_frame[optimal].sort_values(\"mean_inference_us\")\n",
